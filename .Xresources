UXTerm*termName: xterm-256color

UXTerm*scrollBar: hide

UXTerm*locale: true
UXTerm*metaSendsEscape: true

UXTerm*vt100.backarrowkey: false
UXTerm*ttymodes: erase ^?

UXTerm*borderWidth: 0

UXTerm*faceName: Hack Nerd Font Mono:style=Regular:antialias=true
UXTerm*faceNameDoublesize: Noto Sans CJK JP
UXTerm*faceSize: 10

UXTerm*background: #202734
UXTerm*foreground: #cbccc6

UXTerm*color0:  #191e2a
UXTerm*color1:  #ff3333
UXTerm*color2:  #bae67e
UXTerm*color3:  #ffa759
UXTerm*color4:  #73d0ff
UXTerm*color5:  #ffd580
UXTerm*color6:  #95e6cb
UXTerm*color7:  #c7c7c7
UXTerm*color8:  #686868
UXTerm*color9:  #f27983
UXTerm*color10: #a6cc70
UXTerm*color11: #ffcc66
UXTerm*color12: #5ccfe6
UXTerm*color13: #ffee99
UXTerm*color14: #95e6cb
UXTerm*color15: #ffffff
