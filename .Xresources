URxvt.scrollBar : false

URxvt.cursorBlink : true

URxvt.visualBell : true

URxvt.fading : 10

URxvt.font : xft:Hack Nerd Font-10, xft:Noto Sans CJK JP-10

URxvt.foreground: #839496
URxvt.background: #022B36
URxvt.cursorColor: #FFFFFF
URxvt.highlightColor: #FFFFFF

!! black dark/light
URxvt.color0:  #002B36
URxvt.color8:  #073642

!! red dark/light
URxvt.color1:  #DC322F
URxvt.color9:  #CB4B16

!! green dark/light
URxvt.color2:  #859900
URxvt.color10: #586E75

!! yellow dark/light
URxvt.color3:  #B58900
URxvt.color11: #657B83

!! blue dark/light
URxvt.color4:  #268BD2
URxvt.color12: #839496

!! magenta dark/light
URxvt.color5:  #D33682
URxvt.color13: #6C71C4

!! cyan dark/light
URxvt.color6:  #2AA198
URxvt.color14: #93A1A1

!! white dark/light
URxvt.color7:  #EEE8D5
URxvt.color15: #FDF6E3

XTerm*termName: xterm-256color

XTerm*locale: true
XTerm*metaSendsEscape: true

XTerm*vt100.backarrowKey: false
XTerm*ttyModes: erase ^?

/* XTerm*reverseVideo: off */

XTerm*borderWidth: 0

XTerm*faceName: Hack Nerd Font:style=Book:antialias=false
XTerm*faceNameDoublesize: Noto Sans CJK JP
XTerm*faceSize: 10

UXTerm*termname: xterm-256color

UXTerm*locale: true
UXTerm*metasendsescape: true

UXTerm*vt100.backarrowkey: false
UXTerm*ttymodes: erase ^?

/* UXTerm*reverseVideo: off */

UXTerm*borderWidth: 0

UXTerm*faceName: Hack Nerd Font:style=Book:antialias=true
UXTerm*faceNameDoublesize: Noto Sans CJK JP
UXTerm*faceSize: 10

UXTerm.foreground: #839496
UXTerm.background: #022B36
UXTerm.cursorColor: #FFFFFF
UXTerm.highlightColor: #FFFFFF

!! black dark/light
UXTerm.color0:  #002B36
UXTerm.color8:  #073642

!! red dark/light
UXTerm.color1:  #DC322F
UXTerm.color9:  #CB4B16

!! green dark/light
UXTerm.color2:  #859900
UXTerm.color10: #586E75

!! yellow dark/light
UXTerm.color3:  #B58900
UXTerm.color11: #657B83

!! blue dark/light
UXTerm.color4:  #268BD2
UXTerm.color12: #839496

!! magenta dark/light
UXTerm.color5:  #D33682
UXTerm.color13: #6C71C4

!! cyan dark/light
UXTerm.color6:  #2AA198
UXTerm.color14: #93A1A1

!! white dark/light
UXTerm.color7:  #EEE8D5
UXTerm.color15: #FDF6E3

Emacs*UseXIM: false
