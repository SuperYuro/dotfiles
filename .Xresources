Emacs*UseXIM: false

UXTerm*termname: xterm-256color

UXTerm*scrollBar: hide

UXTerm*locale: true
UXTerm*metaSendsEscape: true

UXTerm*vt100.backarrowkey: false
UXTerm*ttymodes: erase ^?

UXTerm*borderWidth: 0

UXTerm*faceName: Hack Nerd Font Mono:style=Regular:antialias=true
UXTerm*faceNameDoublesize: Noto Sans CJK JP
UXTerm*faceSize: 10

UXTerm*background: #e8e9ec
UXTerm*foreground: #33374c

UXTerm*color0:  #dcdfe7
UXTerm*color1:  #cc517a
UXTerm*color2:  #668e3d
UXTerm*color3:  #e57339
UXTerm*color4:  #2d539e
UXTerm*color5:  #7759b4
UXTerm*color6:  #3f83a6
UXTerm*color7:  #33374c
UXTerm*color8:  #8389a3
UXTerm*color9:  #cc3768
UXTerm*color10: #598030
UXTerm*color11: #b6662d
UXTerm*color12: #22478e
UXTerm*color13: #6845ad
UXTerm*color14: #327698
UXTerm*color15: #262a3f
