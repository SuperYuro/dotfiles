URxvt.color9:  rgb:bf/61/6a
URxvt.color10: rgb:a3/be/8c
URxvt.color11: rgb:eb/cb/8b
URxvt.color12: rgb:81/a1/c1
URxvt.color13: rgb:b4/8e/ad
URxvt.color14: rgb:8f/bc/bb
URxvt.color15: rgb:ec/ef/f4

UXTerm*termname: xterm-256color

UXTerm*scrollBar: hide

UXTerm*locale: true
UXTerm*metaSendsEscape: true

UXTerm*vt100.backarrowkey: false
UXTerm*ttymodes: erase ^?

UXTerm*borderWidth: 0

UXTerm*faceName: Hack Nerd Font Mono:style=Regular:antialias=true
UXTerm*faceNameDoublesize: Noto Sans CJK JP
UXTerm*faceSize: 10

UXTerm*background: rgb:2e/34/40
UXTerm*foreground: rgb:d8/de/e9

