Emacs*UseXIM: false

URxvt.font: xft:Hack Nerd Font Mono:style=Regular:size=9

URxvt.letterSpace: -1

URxvt.scrollBar: Hide

URxvt.background: rgb:2e/34/40
URxvt.foreground: rgb:d8/de/e9

URxvt.color0:  rgb:3b/42/52
URxvt.color1:  rgb:bf/61/6a
URxvt.color2:  rgb:a3/be/8c
URxvt.color3:  rgb:eb/cb/8b
URxvt.color4:  rgb:81/a1/c1
