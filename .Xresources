Emacs*UseXIM: false

UXTerm*termname: xterm-256color

UXTerm*locale: true
UXTerm*metaSendsEscape: true

UXTerm*vt100.backarrowkey: false
UXTerm*ttymodes: erase ^?

UXTerm*borderWidth: 0

UXTerm*faceName: Cascadia Mono:style=Regular:antialias=true
UXTerm*faceNameDoublesize: Noto Sans CJK JP
UXTerm*faceSize: 10

UXTerm.background: #ffffff
UXTerm.foreground: #171421

UXTerm.color0:  #171421
UXTerm.color1:  #c01c28
UXTerm.color2:  #26a269
UXTerm.color3:  #a2734c
UXTerm.color4:  #12488b
UXTerm.color5:  #a347ba
UXTerm.color6:  #2aa1b3
UXTerm.color7:  #d0cfcc
UXTerm.color8:  #5e5c64
UXTerm.color9:  #f66151
UXTerm.color10: #33d17a
UXTerm.color11: #e9ad0c
UXTerm.color12: #2a7bde
UXTerm.color13: #c061cb
UXTerm.color14: #33c7de
UXTerm.color15: #ffffff
