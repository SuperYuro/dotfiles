URxvt.scrollBar : false

URxvt.cursorBlink : true

URxvt.visualBell : true

URxvt.fading : 10

URxvt.font : xft:Hack Nerd Font-10, xft:Noto Sans CJK JP-10

URxvt.background : #f9f9f9
URxvt.foreground : #000000

XTerm*termName: xterm-256color

XTerm*locale: true
XTerm*metaSendsEscape: true

XTerm*vt100.backarrowKey: false
XTerm*ttyModes: erase ^?

/* XTerm*reverseVideo: off */

XTerm*borderWidth: 0

XTerm*faceName: Hack Nerd Font:style=Book:antialias=false
XTerm*faceNameDoublesize: Noto Sans CJK JP
XTerm*faceSize: 10


uxterm*termname: xterm-256color

uxterm*locale: true
uxterm*metasendsescape: true

uxterm*vt100.backarrowkey: false
uxterm*ttymodes: erase ^?

/* UXTerm*reverseVideo: off */

UXTerm*borderWidth: 0

UXTerm*faceName: Hack Nerd Font:style=Book:antialias=true
UXTerm*faceNameDoublesize: Noto Sans CJK JP
UXTerm*faceSize: 10

Emacs*UseXIM: false
